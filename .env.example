# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it's gitignored.

APP_PASSWORD=your_password_here
GOOGLE_SHEET_ID=paste_sheet_id_from_url_here

# Partner Exit Tracker (Railway) — view-only credentials
# Used ONLY for: POST /login + GET endpoints. No PUT/PATCH/DELETE. No admin actions.
EXIT_TRACKER_URL=https://partner-exit-tracker-production-2b9e.up.railway.app
EXIT_TRACKER_EMAIL=your_view_only_email@wiom.in
EXIT_TRACKER_PASSWORD=your_view_only_password

# Supabase (anon key from partner-exit-tracker JS bundle; public by design, RLS-protected)
SUPABASE_URL=https://zlleobkgjbjehqxsbzci.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Metabase (read-only API key)
METABASE_URL=https://metabase.wiom.in
METABASE_API_KEY=your_metabase_api_key
